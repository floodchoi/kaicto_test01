# 로컬 개발: 로컬 Postgres
DATABASE_URL=postgresql://localhost:5432/meeting_minutes

# 앱 로그인 비밀번호 (필수 — 미설정 시 모든 API가 잠김)
# Vercel에도 같은 이름으로 환경변수 추가 필요
APP_PASSWORD=change-me

# 프로덕션(Vercel): Neon 풀러 연결 (host에 -pooler 포함)
# Neon → Dashboard → Connection Details → "Pooled connection" 을 복사.
# DATABASE_URL=postgresql://[USER]:[PASSWORD]@ep-xxxx-pooler.[REGION].aws.neon.tech/[DB]?sslmode=require

# Gemini API 키는 서버 환경변수가 아니라 웹앱 설정(⚙️)에서 사용자가 직접 입력합니다.
# (브라우저 localStorage에 보관, 요청마다 전달)
